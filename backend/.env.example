# Environment Variables for Tumbuh Backend
# Copy this file to .env and fill in your values

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_NAME=tumbuh_db

# JWT
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# File uploads
UPLOAD_DIR=uploads
